<idea-plugin>
    <!-- 插件 ID 由 build.gradle.kts 动态注入 -->
    <id>com.antoniofuture.ideeventsounds.intellij</id>

    <!-- 版本号由 build.gradle.kts 动态注入 -->
    <name>IDE Event Sounds</name>

    <!-- 作者信息从统一配置读取 -->
    <vendor email="antonioliang@Foxmail.com" url="https://github.com/antoniofuture/ide-event-sounds">Antonio Future</vendor>

    <!-- 描述由 build.gradle.kts 动态注入 -->
    <description><![CDATA[
    <h2>IDE Event Sounds</h2>
    <p>为 IntelliJ 平台 IDE 提供事件声音自定义功能，让开发者通过专属语音/音效感知 IDE 关键事件。</p>
    <ul>
        <li>构建成功/失败提示音</li>
        <li>运行启动/终止提示音</li>
        <li>编译完成提示音</li>
        <li>测试通过/失败提示音</li>
    </ul>
    ]]></description>

    <!-- 变更日志由 build.gradle.kts 动态注入 -->
    <change-notes><![CDATA[
    <h3>0.0.4</h3>
    <ul>
        <li>新增 Settings UI 配置界面</li>
        <li>支持在设置界面添加/编辑/删除事件绑定</li>
        <li>支持在设置界面配置正则匹配规则</li>
        <li>支持测试播放声音预览</li>
        <li>支持启用/禁用单个事件</li>
    </ul>
    <h3>0.0.3</h3>
    <ul>
        <li>支持通知消息正则匹配功能</li>
        <li>新增测试通知发送功能</li>
    </ul>
    <h3>0.0.2</h3>
    <ul>
        <li>支持自定义事件绑定和声音配置</li>
        <li>支持 40+ IntelliJ 原生事件监听</li>
        <li>支持自定义本地音频文件路径</li>
        <li>支持启用/禁用单个事件</li>
        <li>新增 Git 操作事件（commit、push、pull、branch、merge 等）</li>
        <li>新增文件操作事件（创建、删除、重命名等）</li>
        <li>配置版本升级到 0.0.2</li>
    </ul>
    <h3>0.0.1</h3>
    <ul>
        <li>初始版本发布</li>
        <li>支持 7 个核心高频事件</li>
        <li>内置预设声音</li>
    </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <application-components>
        <component>
            <implementation-class>com.antoniofuture.ideeventsounds.intellij.plugin.FileEventsService</implementation-class>
        </component>
    </application-components>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.antoniofuture.ideeventsounds.intellij.plugin.EventSoundsPluginService"/>
        <projectConfigurable instance="com.antoniofuture.ideeventsounds.intellij.settings.EventSoundsConfigurable"/>
    </extensions>

    <applicationListeners>
        <listener class="com.antoniofuture.ideeventsounds.intellij.listeners.ExecutionEventsListener" topic="com.intellij.execution.ExecutionListener"/>
        <listener class="com.antoniofuture.ideeventsounds.intellij.listeners.ProjectOpenListener" topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>

    <projectListeners>
        <listener class="com.antoniofuture.ideeventsounds.intellij.listeners.BuildEventsListener" topic="com.intellij.task.ProjectTaskListener"/>
    </projectListeners>
</idea-plugin>