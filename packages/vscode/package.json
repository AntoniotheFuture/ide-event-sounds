{
  "name": "ide-event-sounds",
  "displayName": "IDE Event Sounds",
  "description": "为 VS Code 提供事件声音自定义功能，让开发者通过专属语音/音效感知 IDE 关键事件",
  "version": "0.0.5",
  "publisher": "antoniofuture",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ide-event-sounds.openConfig",
        "title": "打开声音配置文件"
      },
      {
        "command": "ide-event-sounds.testNotification",
        "title": "发送测试通知"
      },
      {
        "command": "ide-event-sounds.toggleEnable",
        "title": "启用/禁用事件声音"
      }
    ],
    "configuration": {
      "title": "IDE Event Sounds",
      "properties": {
        "ideEventSounds.enable": {
          "type": "boolean",
          "default": true,
          "description": "启用或禁用所有事件声音"
        },
        "ideEventSounds.configPath": {
          "type": "string",
          "default": "",
          "description": "配置文件路径（默认为 ~/.ide-event-sounds/config.json）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node scripts/package.js",
    "package:vsce": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniofuture/ide-event-sounds"
  }
}
